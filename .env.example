# AgentRoute Oracle Configuration

# Service
SERVICE_NAME=AgentRoute Oracle
SERVICE_VERSION=1.0.0
ENVIRONMENT=development

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=INFO

# L402 / Aperture
MACAROON_KEY=dev-key-12345
PREIMAGE_KEY=dev-preimage-12345
L402_ENABLED=true

# Lightning Network
LND_HOST=localhost
LND_PORT=10009
LND_MACAROON_PATH=~/.lnd/data/chain/bitcoin/mainnet/admin.macaroon
LND_TLS_CERT_PATH=~/.lnd/tls.cert
LND_NETWORK=mainnet

# Pricing
BASE_PRICE_SATS=10
MAX_PRICE_SATS=30
DYNAMIC_PRICING_ENABLED=true

# Database (optional - for future revenue tracking)
DATABASE_URL=sqlite:///agentroute.db

# Monitoring
METRICS_ENABLED=true
SENTRY_DSN=

# External Services
AGENT_DIRECTORY_URL=https://clawhub.xyz
AGENT_DIRECTORY_API_KEY=

# Bitcoin
BITCOIN_NETWORK=mainnet
