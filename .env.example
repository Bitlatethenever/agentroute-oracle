# AgentRoute Oracle Configuration

# Service
SERVICE_NAME=AgentRoute Oracle
SERVICE_VERSION=1.0.0
ENVIRONMENT=production

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=INFO

# L402 / Aperture
MACAROON_KEY=dev-key-12345
PREIMAGE_KEY=dev-preimage-12345
L402_ENABLED=true

# ============================================================================
# Lightning Network Configuration (Voltage LND Node)
# ============================================================================

# LND Node REST API Configuration
LND_HOST=agentroute-oracle.m.voltageapp.io
LND_REST_PORT=8080
LND_GRPC_PORT=10009

# Admin Macaroon (hex format) - Get from Voltage dashboard Macaroon Bakery
# This is the admin macaroon that allows full access to LND node
LND_ADMIN_MACAROON_

# TLS Certificate Path (for self-signed certificates from Voltage)
LND_TLS_CERT_PATH=/etc/lnd/tls.cert

# Lightning Network
LND_NETWORK=mainnet

# Pricing
BASE_PRICE_SATS=10
MAX_PRICE_SATS=30
DYNAMIC_PRICING_ENABLED=true

# Payment
ALBY_LIGHTNING_ADDRESS=jocundpresence451531@getalby.com

# Database (optional - for future revenue tracking)
DATABASE_URL=sqlite:///agentroute.db

# Monitoring
METRICS_ENABLED=true
SENTRY_DSN=

# External Services
AGENT_DIRECTORY_URL=https://clawhub.xyz
AGENT_DIRECTORY_API_KEY=

# Bitcoin
BITCOIN_NETWORK=mainnet
